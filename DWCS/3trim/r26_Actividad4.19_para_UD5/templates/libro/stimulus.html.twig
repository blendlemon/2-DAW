{% extends 'base.html.twig' %}

{% block title %}Listado de libros
{% endblock %}

{% block body %}
	<div data-controller="libros">
		<h2>Listado de libros</h2>
		<ul>
			{% for libro in libros %}
				<li>{{libro.id}}-
					{{ libro.titulo }}
				</li>
			{% endfor %}
		</ul>


		<div class="row">
			<button id="btnLibros" type="button" class="col-5 btn btn-secondary mx-2" data-action="click->libros#cargarLibros">
				Cargar libros del servicio web
			</button>
			<button id="btnCrearLibro" type="button" class=" col-5 btn btn-primary mx-2" data-action="click->libros#mostrarCrear">
				Crear nuevo libro
			</button>
		</div>
		<div id="buzonMensajes" class="alert" style="display: none;" role="alert"></div>
		<div id="divFormCrear" style="display: none;" class="mt-4 p-3 border rounded bg-light" data-libros-target="formularioContenedor">
			<h3>
				Nuevo Libro
			</h3>
			<div id="contenedorErrores" class="alert alert-danger" style="display: none;">
				<ul id="listaErrores" class="mb-0"></ul>
			</div>
			<form id="formLibro" data-libros-target="form">
				<div class="mb-3">
					<label for="titulo" class="form-label">
						Título
					</label>
					<input type="text" id="titulo" class="form-control" required data-libros-target="titulo">
					<textarea id="descripcion" class="form-control mb-3" placeholder="Descripción del libro" rows="3" data-libros-target="descripcion"></textarea>
					<button type="submit" class="btn btn-success" data-action="click->libros#crearLibro">
						Guardar en API
					</button>
					<button type="button" id="btnCancelar" class="btn btn-link" data-action="click->libros#ocultarCrear">
						Cancelar
					</button>
				</div>
			</form>
		</div>

		<div id="divListaLibrosApi" class="mt-4" style="display: none;" data-libros-target="divListaLibrosApi">
			<h2>
				Listado de libros del API REST
			</h2>
			{# <ul id="listaLibrosApi"></ul> #}
			<table class="table table-striped table-hover">
				<thead class="table">
					<tr>
						<th>
							ID
						</th>
						<th>
							Título
						</th>
						<th>
							Descripción
						</th>
						<th class="text-center">
							Acciones
						</th>
					</tr>
				</thead>
				<tbody id="cuerpoTablaLibros" data-libros-target="cuerpoTablaLibros" data-action="click->libros#confirmarEliminarLibro"></tbody>
			</table>
		</div>
	</div>
{% endblock %}
